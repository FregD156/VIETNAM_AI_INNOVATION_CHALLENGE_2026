  "rawNodes": [
    { "id": "doc_tt39", "label": "Document", "properties": { "id": "tt39", "title": "Thông tư 39/2016/TT-NHNN", "type": "NHNN", "effective_date": "2016-12-30" } },
    { "id": "clause_5_tt39", "label": "Clause", "properties": { "id": "clause_5_tt39", "title": "Điều 5 - Thông tư 39", "text": "Phương thức gia hạn nợ và lãi suất gia hạn do TCTD tự thỏa thuận...", "status": "expired", "effective_date": "2016-12-30" } },
    
    { "id": "doc_tt06", "label": "Document", "properties": { "id": "tt06", "title": "Thông tư 06/2023/TT-NHNN", "type": "NHNN", "effective_date": "2023-09-01" } },
    { "id": "clause_5_tt06", "label": "Clause", "properties": { "id": "clause_5_tt06", "title": "Điều 5 - Thông tư 06", "text": "Hạn mức cho vay online tiêu dùng qua kênh điện tử tối đa không vượt quá 100.000.000 VNĐ.", "status": "active", "effective_date": "2023-09-01" } },
    
    { "id": "doc_qd214", "label": "Document", "properties": { "id": "qd214", "title": "Quyết định 214/2022/SHB", "type": "SHB_Internal", "effective_date": "2022-04-15" } },
    { "id": "clause_14_qd214", "label": "Clause", "properties": { "id": "clause_14_qd214", "title": "Điều 14 - QĐ 214/2022/SHB", "text": "Đối với vay tiêu dùng tín chấp dành cho đối tác liên kết của SHB, hạn mức cho vay tối đa là 500.000.000 VNĐ.", "status": "expired", "effective_date": "2022-04-15" } },
    
    { "id": "doc_tt16", "label": "Document", "properties": { "id": "tt16", "title": "Thông tư 16/2020/TT-NHNN", "type": "NHNN", "effective_date": "2020-12-04" } },
    { "id": "clause_12_tt16", "label": "Clause", "properties": { "id": "clause_12_tt16", "title": "Điều 12 - Thông tư 16", "text": "Ngân hàng thương mại mở tài khoản thanh toán bằng eKYC phải áp dụng hạn mức tối đa 100 triệu đồng/tháng.", "status": "active", "effective_date": "2020-12-04" } },
    
    { "id": "doc_qd104", "label": "Document", "properties": { "id": "qd104", "title": "Quyết định 104/2024/SHB", "type": "SHB_Internal", "effective_date": "2024-01-10" } },
    { "id": "clause_9_qd104", "label": "Clause", "properties": { "id": "clause_9_qd104", "title": "Điều 9 - QĐ 104/2024/SHB", "text": "Mở tài khoản eKYC phải thu thập CCCD gắn chip, hạn mức giao dịch không vượt quá 100 triệu đồng/tháng.", "status": "active", "effective_date": "2024-01-10" } },
    
    { "id": "doc_qd_tietkiem", "label": "Document", "properties": { "id": "qd_tietkiem", "title": "Quy chế Tiết kiệm SHB 2025", "type": "SHB_Internal", "effective_date": "2025-01-01" } },
    { "id": "clause_5_qd_tietkiem", "label": "Clause", "properties": { "id": "clause_5_qd_tietkiem", "title": "Điều 5 - Quy chế Tiết kiệm SHB", "text": "Trường hợp đến ngày đến hạn mà người gửi tiền không đến rút, tổ chức tín dụng sẽ tự động gia hạn cả gốc và lãi sang kỳ hạn mới tương đương kỳ hạn cũ. Lãi suất áp dụng là lãi suất công bố của SHB tại ngày tái tục.", "status": "active", "effective_date": "2025-01-01" } }
